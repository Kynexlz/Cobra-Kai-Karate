-- Pushup Toggle + Loop
pushupButton.MouseButton1Click:Connect(function()
    pushupActive = not pushupActive
    if pushupActive then
        pushupButton.Text = "Pushup: ON"
        pushupButton.TextColor3 = Color3.fromRGB(80, 255, 80)
        
        pushupLoop = game:GetService("RunService").Heartbeat:Connect(function()
            game:GetService("ReplicatedStorage").Remotes.PushUp:FireServer("{}")
        end)
    else
        pushupButton.Text = "Pushup: OFF"
        pushupButton.TextColor3 = Color3.fromRGB(255, 80, 80)
        if pushupLoop then
            pushupLoop:Disconnect()
            pushupLoop = nil
        end
    end
end)

